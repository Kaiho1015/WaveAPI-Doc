      "anchors": [
        {
          "anchor": "Status",
          "icon": "signal",
          "href": "https://ai.kaiho.cc"
        },
        {
          "anchor": "Community",
          "icon": "discord",
          "href": "https://discord.gg/你的邀请码"
        },
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/Kaiho1015/docs"
        }
      ]
