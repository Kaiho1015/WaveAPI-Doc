{
  "$schema": "https://mintlify.com/docs.json",
  "name": "QWave API",
  "theme": "maple",
  "colors": {
    "primary": "#0EA5E9",
    "light": "#38BDF8",
    "dark": "#0284C7"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "appearance": {
    "default": "system"
  },
  "background": {
    "decoration": "gradient"
  },
  "styling": {
    "eyebrows": "section",
    "codeblocks": "system"
  },
  "search": {
    "prompt": "Search docs..."
  },
  "api": {
    "examples": {
      "languages": [
        "curl",
        "python",
        "javascript",
        "go",
        "java"
      ]
    },
    "playground": {
      "display": "simple"
    }
  },
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://qingbo.dev/dashboard/keys"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Status",
          "icon": "signal",
          "href": "https://status.qingboai.com"
        },
        {
          "anchor": "Community",
          "icon": "discord",
          "href": "https://discord.gg/你的邀请码"
        },
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/Kaiho1015/docs"
        }
      ]
    },
    "languages": [
      {
        "language": "cn",
        "tabs": [
          {
            "tab": "文档",
            "icon": "book-open",
            "groups": [
              {
                "group": "开始",
                "pages": [
                  "cn/index",
                  "cn/guides/quickstart",
                  "cn/docs/authentication"
                ]
              },
              {
                "group": "核心概念",
                "pages": [
                  "cn/docs/request-response",
                  "cn/docs/sync-async",
                  "cn/docs/task-system",
                  "cn/docs/streaming",
                  "cn/docs/models"
                ]
              }
            ]
          },
          {
            "tab": "API 参考",
            "icon": "code",
            "groups": [
              {
                "group": "文本生成",
                "pages": [
                  "cn/api-reference/text/general-chat",
                  "cn/api-reference/text/claude-messages",
                  "cn/api-reference/text/gemini-native",
                  "cn/api-reference/text/openai-multimodal"
                ]
              },
              {
                "group": "图像生成",
                "pages": [
                  "cn/api-reference/image/overview",
                  "cn/api-reference/image/gemini",
                  "cn/api-reference/image/gpt-image",
                  "cn/api-reference/image/seedream",
                  "cn/api-reference/image/imagen",
                  "cn/api-reference/image/qwen-image",
                  "cn/api-reference/image/wan-image",
                  "cn/api-reference/image/z-image"
                ]
              },
              {
                "group": "视频生成",
                "pages": [
                  "cn/api-reference/video/overview",
                  "cn/api-reference/video/veo",
                  "cn/api-reference/video/seedance",
                  "cn/api-reference/video/kling",
                  "cn/api-reference/video/hailuo",
                  "cn/api-reference/video/vidu",
                  "cn/api-reference/video/wan",
                  "cn/api-reference/video/happyhorse",
                  "cn/api-reference/video/skyreels",
                  "cn/api-reference/video/grok-imagine-video"
                ]
              },
              {
                "group": "音频处理",
                "pages": [
                  "cn/api-reference/audio/tts",
                  "cn/api-reference/audio/whisper-transcription"
                ]
              },
              {
                "group": "工具与嵌入",
                "pages": [
                  "cn/api-reference/tools/embeddings",
                  "cn/api-reference/tools/moderations",
                  "cn/api-reference/tools/rerank"
                ]
              },
              {
                "group": "任务管理",
                "pages": [
                  "cn/api-reference/task/submit",
                  "cn/api-reference/task/sync",
                  "cn/api-reference/task/status",
                  "cn/api-reference/task/cancel"
                ]
              }
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Kaiho1015/WaveAPI-Doc",
      "discord": "https://discord.gg/你的邀请码",
      "website": "https://qingbo.dev"
    }
  }
}
