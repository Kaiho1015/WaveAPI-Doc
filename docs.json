{
  "$schema": "https://mintlify.com/docs.json",
  "name": "WaveAPI",
  "theme": "maple",

  "colors": {
    "primary": "#0EA5E9",
    "light": "#38BDF8",
    "dark": "#0284C7"
  },

  "favicon": "/favicon.svg",

  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },

  "appearance": {
    "default": "system"
  },

  "background": {
    "decoration": "gradient"
  },

  "styling": {
    "eyebrows": "section",
    "codeblocks": "system"
  },

  "search": {
    "prompt": "Search docs..."
  },

  "api": {
    "examples": {
      "languages": ["curl", "python", "javascript", "go", "java"]
    },
    "playground": {
      "display": "simple"
    }
  },

  "navbar": {
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://ai.kaiho.cc/token"
    }
  },

  "navigation": {
